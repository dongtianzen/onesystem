{#
/**
 * @file
 * OB Barrio — Front page template (page--front.html.twig).
 *
 * Sections:
 *   1. Hero Banner
 *   2. Core Products  (light gray bg)
 *   3. Service Capabilities (navy bg)
 *   4. Partner Brands (white bg)
 *   5. CTA Banner  (accent blue bg)
 *   6. Footer  (dark navy bg — reuses ob-footer styles)
 *
 * Variables:
 *   page.*          — Drupal regions
 *   current_langcode — 'zh-hans' | 'en' (from ob_barrio_preprocess_page)
 *   year            — current year (from ob_barrio_preprocess_page)
 */
#}
{% set zh = (current_langcode == 'zh-hans') %}

<div id="page-wrapper">
<div id="page">

  <a href="#main-content" class="visually-hidden-focusable">{{ 'Skip to main content'|t }}</a>

  {# ════════════════════════════════════════
     HEADER — identical to page.html.twig
     ════════════════════════════════════════ #}
  <header id="site-header" class="ob-header sticky-top" role="banner">
    <div class="ob-header__topbar"></div>
    <div class="container">
      <div class="ob-header__inner">

        <div class="ob-header__brand">
          {{ page.header }}
        </div>

        <div class="ob-header__primary-region">
          {{ page.primary_menu }}
        </div>

        <button class="navbar-toggler d-lg-none ms-auto"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#ob-mobile-nav"
                aria-controls="ob-mobile-nav"
                aria-expanded="false"
                aria-label="{{ 'Toggle navigation'|t }}">
          <span class="navbar-toggler-icon"></span>
        </button>

      </div>

      <div class="collapse d-lg-none" id="ob-mobile-nav">
        <div class="ob-mobile-menu">
          {{ page.primary_menu }}
        </div>
      </div>
    </div>
  </header>

  {# System messages #}
  {% if page.highlighted %}
  <div class="highlighted">
    <aside class="container section clearfix" role="complementary">
      {{ page.highlighted }}
    </aside>
  </div>
  {% endif %}

  <main id="main-content" tabindex="-1">

    {# ════════════════════════════════════════
       SECTION 1 — HERO BANNER
       ════════════════════════════════════════ #}
    <section class="ob-front-hero" aria-label="{{ 'Hero'|t }}">
      <div class="ob-front-hero__bg-dots" aria-hidden="true"></div>
      <div class="ob-front-hero__glow" aria-hidden="true"></div>

      <div class="container">
        <div class="ob-front-hero__inner">

          {# Pill tag row #}
          <div class="ob-front-hero__pills">
            <span class="ob-front-pill ob-front-pill--brand">{{ zh ? '5G直播与制作' : '5G Live Production' }}</span>
            <span class="ob-front-pill ob-front-pill--sep" aria-hidden="true">·</span>
            <span class="ob-front-pill ob-front-pill--brand">{{ zh ? '视频处理与播出' : 'Video Processing & Broadcasting' }}</span>
            <span class="ob-front-pill ob-front-pill--sep" aria-hidden="true">·</span>
            <span class="ob-front-pill ob-front-pill--brand">{{ zh ? '4K编码解码' : '4K Encoding & Decoding' }}</span>
          </div>

          {# Main headline #}
          <h1 class="ob-front-hero__title">
            <span class="ob-front-hero__title-line1">{{ zh ? '面向未来的' : 'Future-Ready' }}</span>
            <span class="ob-front-hero__title-line2">{{ zh ? '广播视频基础设施' : 'Broadcast &amp; Video Infrastructure' }}</span>
          </h1>

          {# Sub-headline #}
          <p class="ob-front-hero__sub">
            {{ zh
              ? '专注卫星通信、视频传输与专业播出领域，为媒体机构提供端到端系统解决方案与技术支持。'
              : 'End-to-end solutions for satellite communication, live production and video networking — trusted by broadcasters worldwide.' }}
          </p>

          {# CTA Buttons #}
          <div class="ob-front-hero__btns">
            <a href="{{ zh ? '/zh/node/484' : '/en/node/484' }}"
               class="ob-front-btn ob-front-btn--primary">
              {{ zh ? '探索核心产品' : 'Explore Products' }}
            </a>
            <a href="{{ zh ? 'https://qingflow.com/f/62b2ca80' : 'https://qingflow.com/f/62b2ca80' }}"
               class="ob-front-btn ob-front-btn--outline">
              {{ zh ? '申请报价' : 'Request Demo' }}
            </a>
          </div>

          {# Stats row #}
          <div class="ob-front-hero__stats">
            <div class="ob-front-stat">
              <span class="ob-front-stat__num">20+</span>
              <span class="ob-front-stat__label">{{ zh ? '年行业经验' : 'Years Experience' }}</span>
            </div>
            <span class="ob-front-stat__divider" aria-hidden="true"></span>
            <div class="ob-front-stat">
              <span class="ob-front-stat__num">500+</span>
              <span class="ob-front-stat__label">{{ zh ? '客户部署案例' : 'Client Deployments' }}</span>
            </div>
            <span class="ob-front-stat__divider" aria-hidden="true"></span>
            <div class="ob-front-stat">
              <span class="ob-front-stat__num">24/7</span>
              <span class="ob-front-stat__label">{{ zh ? '技术支持保障' : 'Technical Support' }}</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    {# ════════════════════════════════════════
       SECTION 2 — CORE PRODUCTS
       ════════════════════════════════════════ #}
    <section class="ob-front-products" aria-label="{{ zh ? '核心产品' : 'Core Products' }}">
      <div class="container">

        <div class="ob-front-section-head ob-front-section-head--split">
          <div class="ob-front-section-head__left">
            <span class="ob-eyebrow">{{ zh ? '核心产品' : 'Core Products' }}</span>
            <h2 class="ob-front-section-title">
              {{ zh ? '专业视音频处理' : 'Professional Audio & Video Processing' }}
            </h2>
          </div>
          <div class="ob-front-section-head__right">
            <p class="ob-front-section-desc">
              {{ zh
                ? '直播与远程制作、视音频处理、播出与存储、传输与分发、演播室集成。'
                : 'Live & Remote Production, Audio/Video Processing, Playout & Storage, Transmission & Distribution, and Studio Integration Solutions.' }}
            </p>
          </div>
        </div>

        <div class="ob-front-product-grid">

          {# Card 1 #}
          <article class="ob-product-card">
            <div class="ob-product-card__badge ob-product-card__badge--primary">{{ zh ? '核心产品' : 'Key Product' }}</div>
            <div class="ob-product-card__icon" aria-hidden="true">📡</div>
            <h3 class="ob-product-card__name">{{ zh ? '5G直播与远程制作' : '5G Live & Remote Production' }}</h3>
            <p class="ob-product-card__desc">
              {{ zh
                ? 'LiveU 4G/5G直播背包、编码器、云管理平台全套解决方案.'
                : 'Complete LiveU 4G/5G Live Backpack, Encoder & Cloud Management Platform Solutions.' }}
            </p>
            <div class="ob-product-card__tags">
              <span class="ob-product-card__tag">LiveU</span>
              <span class="ob-product-card__tag">4G/5G</span>
              <span class="ob-product-card__tag">Central</span>
            </div>
            <a href="{{ zh ? '/zh/node/LiveU背包' : '/en/node/LiveU背包' }}"
               class="ob-product-card__link" aria-label="{{ zh ? '5G直播与远程制作' : '5G Live & Remote Production' }}">→</a>
          </article>

          {# Card 2 #}
          <article class="ob-product-card">
            <div class="ob-product-card__badge ob-product-card__badge--agent">{{ zh ? '授权代理' : 'Authorised' }}</div>
            <div class="ob-product-card__icon" aria-hidden="true">🎬</div>
            <h3 class="ob-product-card__name">{{ zh ? '视音频处理、播出与存储' : 'Audio/Video Processing, Playout & Storage' }}</h3>
            <p class="ob-product-card__desc">
              {{ zh
                ? '采用 哈雷 等顶级品牌，提供视编码与处理、播出与存储。'
                : 'Powered by industry-leading brands such as Harmonic, we provide comprehensive video encoding, processing, playout, and storage solutions.' }}
            </p>
            <div class="ob-product-card__tags">
              <span class="ob-product-card__tag">Harmonic</span>
              <span class="ob-product-card__tag">MediaKind</span>
              <span class="ob-product-card__tag">XOS</span>
              <span class="ob-product-card__tag">ProStream</span>
              <span class="ob-product-card__tag">ProSwitch</span>
              <span class="ob-product-card__tag">Spectrum X</span>
              <span class="ob-product-card__tag">MediaGrid</span>
            </div>
            <a href="{{ zh ? '/zh/node/哈雷视频产品' : '/en/node/哈雷视频产品' }}"
               class="ob-product-card__link" aria-label="{{ zh ? '查看直播产品' : 'View live encoding' }}">→</a>
          </article>

          {# Card 3 #}
          <article class="ob-product-card">
            <div class="ob-product-card__badge ob-product-card__badge--agent">{{ zh ? '授权代理' : 'Authorised' }}</div>
            <div class="ob-product-card__icon" aria-hidden="true">🖥️</div>
            <h3 class="ob-product-card__name">{{ zh ? '传输与分发' : 'Transmission & Distribution' }}</h3>
            <p class="ob-product-card__desc">
              {{ zh
                ? '采用 Appear 等品牌专业视频处理设备，覆盖多格式转换、上下变换与监测。'
                : 'Leveraging professional video processing solutions from industry-leading brands such as Appear, we provide comprehensive support for multi-format conversion, up/down/cross conversion, and signal monitoring.' }}
            </p>
            <div class="ob-product-card__tags">
              <span class="ob-product-card__tag">Appear</span>
              <span class="ob-product-card__tag">MediaKind</span>
              <span class="ob-product-card__tag">Harmonic</span>
              <span class="ob-product-card__tag">Ateme</span>
              <span class="ob-product-card__tag">ETL</span>
              <span class="ob-product-card__tag">Newtec</span>
            </div>
            <a href="{{ zh ? '/zh/dashboard/category/product' : '/en/dashboard/category/product' }}"
               class="ob-product-card__link" aria-label="{{ zh ? '查看视频处理设备' : 'View video processing' }}">→</a>
          </article>

          {# Card 4 #}
          <article class="ob-product-card">
            <div class="ob-product-card__badge ob-product-card__badge--primary">{{ zh ? '主流产品' : 'Featured Products' }}</div>
            <div class="ob-product-card__icon" aria-hidden="true">🌐</div>
            <h3 class="ob-product-card__name">{{ zh ? '演播室系统' : 'Studio Systems' }}</h3>
            <p class="ob-product-card__desc">
              {{ zh
                ? '基于 IP 网络的视频传输与调度平台，支持低延迟、高可靠的专业媒体信号分发。'
                : 'IP-based video transport and scheduling platform for low-latency, high-reliability professional media distribution.' }}
            </p>
            <div class="ob-product-card__tags">
              <span class="ob-product-card__tag">SONY</span>
              <span class="ob-product-card__tag">Arkora</span>
              <span class="ob-product-card__tag">Clear-COM</span>
              <span class="ob-product-card__tag">RIEDEL</span>
              <span class="ob-product-card__tag">Imagine</span>
              <span class="ob-product-card__tag">GV</span>
              <span class="ob-product-card__tag">PHABRIX</span>
            </div>
            <a href="{{ zh ? '/zh/dashboard/category/product' : '/en/dashboard/category/product' }}"
               class="ob-product-card__link" aria-label="{{ zh ? '查看网络传输平台' : 'View network platform' }}">→</a>
          </article>

        </div>{# /ob-front-product-grid #}
      </div>
    </section>

    {# ════════════════════════════════════════
       SECTION 3 — SERVICE CAPABILITIES
       ════════════════════════════════════════ #}
    <section class="ob-front-services" aria-label="{{ zh ? '服务能力' : 'Services' }}">
      <div class="container">

        <div class="ob-front-section-head">
          <span class="ob-eyebrow ob-eyebrow--light">{{ zh ? '服务能力' : 'Our Services' }}</span>
          <h2 class="ob-front-section-title ob-front-section-title--light">
            <a href="{{ zh ? '/zh/node/476' : '/en/node/476' }}" class="ob-front-section-title__link">
              {{ zh ? '从咨询到交付的全周期支持' : 'Full-Lifecycle Support from Consulting to Delivery' }}
            </a>
          </h2>
        </div>

        <div class="ob-front-services-grid">

          <a href="https://qingflow.com/f/62b2ca80" class="ob-service-item ob-service-item--linked" target="_blank" rel="noopener noreferrer">
            <span class="ob-service-item__num" aria-hidden="true">01</span>
            <h3 class="ob-service-item__title">{{ zh ? '系统规划与设计' : 'System Planning &amp; Design' }}</h3>
            <p class="ob-service-item__desc">
              {{ zh
                ? '根据业务需求进行系统架构规划，输出详细技术方案与设备选型建议。'
                : 'Tailored system architecture planning with detailed technical proposals and equipment recommendations.' }}
            </p>
          </a>

          <a href="{{ zh ? '/zh/dashboard/service/integration' : '/en/dashboard/service/integration' }}" class="ob-service-item ob-service-item--linked">
            <span class="ob-service-item__num" aria-hidden="true">02</span>
            <h3 class="ob-service-item__title">{{ zh ? '系统集成与设备部署' : 'System Integration & Equipment Deployment' }}</h3>
            <p class="ob-service-item__desc">
              {{ zh
                ? '专业技术工程师团队提供端到端的交钥匙工程服务，确保系统安全稳定上线运行。'
                : 'Professional engineering teams provide end-to-end turnkey solutions, ensuring secure, reliable, and seamless system deployment and operation.' }}
            </p>
          </a>

          <a href="https://qingflow.com/f/5mh8pa0r3401" class="ob-service-item ob-service-item--linked" target="_blank" rel="noopener noreferrer">
            <span class="ob-service-item__num" aria-hidden="true">03</span>
            <h3 class="ob-service-item__title">{{ zh ? '技术支持' : 'Technical Support' }}</h3>
            <p class="ob-service-item__desc">
              {{ zh
                ? 'Oneband远程支持申请：当您不确定设备或系统是否发生了故障，可以申请远程支持，我们会远程帮助您判断。请提前装好Todesk或向日葵'
                : 'Oneband Remote Support Request: If you are unsure whether your equipment or system has encountered a fault, submit a remote support request and our team will diagnose it remotely. Please have ToDesk or Sunflower installed in advance.' }}
            </p>
          </a>

          <a href="https://qingflow.com/f/da3638c5" class="ob-service-item ob-service-item--linked" target="_blank" rel="noopener noreferrer">
            <span class="ob-service-item__num" aria-hidden="true">04</span>
            <h3 class="ob-service-item__title">{{ zh ? '专业售后维修服务' : 'Professional After-Sales Repair Services' }}</h3>
            <p class="ob-service-item__desc">
              {{ zh
                ? '提供全系列产品备品备件替换及故障设备的检测维修服务。在线申请，维修流程线上可查，专业可靠。'
                : 'We provide spare parts replacement and diagnostic repair services for our full range of products. Customers can submit service requests online and track the repair process in real time, ensuring a professional, reliable, and transparent service experienceg.' }}
            </p>
          </a>

        </div>

      </div>
    </section>

    {# ════════════════════════════════════════
       SECTION 4 — PARTNER BRANDS
       ════════════════════════════════════════ #}
    <section class="ob-front-brands" aria-label="{{ zh ? '合作品牌' : 'Partner Brands' }}">
      <div class="container">

        <div class="ob-front-section-head ob-front-section-head--center">
          <span class="ob-eyebrow">{{ zh ? '授权代理 · 战略合作品牌' : 'Authorised Reseller &amp; Strategic Partners' }}</span>
          <h2 class="ob-front-section-title">
            <a href="{{ zh ? '/zh/node/485' : '/en/node/485' }}" class="ob-front-section-title__link">
              {{ zh ? '与全球顶级广播技术品牌深度合作' : 'Deep Partnerships with World-Leading Broadcast Technology Brands' }}
            </a>
          </h2>
        </div>

        <div class="ob-front-brands-grid">
          <div class="ob-brand-item"><a href="/{{ zh ? 'zh' : 'en' }}/taxonomy/term/10">LiveU</a></div>
          <div class="ob-brand-item"><a href="/{{ zh ? 'zh' : 'en' }}/taxonomy/term/27">Harmonic/Mediakind</a></div>
          <div class="ob-brand-item"><a href="/{{ zh ? 'zh' : 'en' }}/taxonomy/term/15">Appear</a></div>
          <div class="ob-brand-item"><a href="/{{ zh ? 'zh' : 'en' }}/taxonomy/term/267">SONY</a></div>
          <div class="ob-brand-item"><a href="/{{ zh ? 'zh' : 'en' }}/taxonomy/term/23">PHABRIX</a></div>
          <div class="ob-brand-item"><a href="/{{ zh ? 'zh' : 'en' }}/taxonomy/term/168">ETL</a></div>
        </div>

      </div>
    </section>

    {# ════════════════════════════════════════
       SECTION 5 — LATEST ARTICLES
       ════════════════════════════════════════ #}
    {% if latest_articles is not empty %}
    <section class="ob-front-articles" aria-label="{{ zh ? '最新文章' : 'Latest Articles' }}">
      <div class="container">

        <div class="ob-front-section-head ob-front-section-head--split">
          <div class="ob-front-section-head__left">
            <h2 class="ob-front-section-title">
              {{ zh ? '最新文章' : 'Latest Articles' }}
            </h2>
          </div>
          <div class="ob-front-section-head__right">
            <a href="{{ zh ? '/zh/dashboard/category/article' : '/en/dashboard/category/article' }}"
               class="ob-front-articles__more">
              {{ zh ? '查看全部文章 →' : 'View all articles →' }}
            </a>
          </div>
        </div>

        <div class="ob-front-articles-grid">
          {% for article in latest_articles %}
          <article class="ob-article-card">
            {% if article.image_url %}
            <a href="{{ article.url }}" class="ob-article-card__img-wrap" tabindex="-1" aria-hidden="true">
              <img src="{{ article.image_url }}" alt="{{ article.title }}" class="ob-article-card__img" loading="lazy">
            </a>
            {% else %}
            {% set placeholders = ['placeholder-satellite.svg', 'placeholder-rack.svg', 'placeholder-network.svg'] %}
            <a href="{{ article.url }}" class="ob-article-card__img-wrap ob-article-card__img-wrap--placeholder" tabindex="-1" aria-hidden="true">
              <img class="ob-article-card__img-placeholder"
                   src="/{{ directory }}/images/index/{{ placeholders[loop.index0 % 3] }}"
                   alt="" aria-hidden="true" loading="lazy">
            </a>
            {% endif %}

            <div class="ob-article-card__body">
              <div class="ob-article-card__meta">
                {% if article.brand %}
                <span class="ob-article-card__brand">{{ article.brand }}</span>
                <span class="ob-article-card__sep" aria-hidden="true">·</span>
                {% endif %}
                <time class="ob-article-card__date" datetime="{{ article.date }}">{{ article.date }}</time>
              </div>

              <h3 class="ob-article-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>

              {% if article.summary %}
              <p class="ob-article-card__summary">{{ article.summary }}</p>
              {% endif %}

              <a href="{{ article.url }}" class="ob-article-card__read-more">
                {{ zh ? '阅读全文' : 'Read more' }} →
              </a>
            </div>
          </article>
          {% endfor %}
        </div>

      </div>
    </section>
    {% endif %}

    {# ════════════════════════════════════════
       SECTION 6 — CTA BANNER
       ════════════════════════════════════════ #}
    <section class="ob-front-cta" aria-label="{{ zh ? '联系我们' : 'Contact Us' }}">
      <div class="container">
        <div class="ob-front-cta__inner">

          <h2 class="ob-front-cta__title">
            {{ zh ? '准备好升级您的播出系统了吗？' : 'Ready to upgrade your broadcast infrastructure?' }}
          </h2>
          <p class="ob-front-cta__desc">
            {{ zh
              ? '我们的工程团队随时准备好为您提供专业咨询，从需求分析到系统交付全程跟进。'
              : 'Our engineering team is ready to provide expert consultation — from requirements analysis to full system delivery.' }}
          </p>

          <div class="ob-front-cta__btns">
            <a href="{{ zh ? '/zh/contact' : '/en/contact' }}"
               class="ob-front-btn ob-front-btn--white-outline">
              {{ zh ? '立即咨询' : 'Contact Us' }}
            </a>
            <a href="{{ zh ? 'https://qingflow.com/qfShare/4lhkbxAf#' : 'https://qingflow.com/qfShare/4lhkbxAf#' }}"
               class="ob-front-btn ob-front-btn--white-solid">
              {{ zh ? '万博开放平台' : 'Oneband Open Platform' }}
            </a>
          </div>

        </div>
      </div>
    </section>

  </main>

  {# ════════════════════════════════════════
     FOOTER
     ════════════════════════════════════════ #}
  <footer class="ob-footer" role="contentinfo">
    <div class="container">

      <div class="ob-footer__top row g-4">

        {# Column 1: Brand + description #}
        <div class="col-12 col-sm-6 col-lg-4 ob-footer__brand">
          {{ page.footer_first }}
          {# Fallback static content when region is empty #}
          {% if page.footer_first|render|striptags|trim is empty %}
          <div class="site-name">
            <a href="{{ zh ? '/zh' : '/en' }}">Oneband System</a>
          </div>
          <p class="ob-footer__desc">
            {{ zh
              ? '专注广播视频基础设施领域，为媒体机构提供专业系统集成与技术支持服务。'
              : 'Broadcast & video infrastructure specialists — system integration and technical services for media organisations.' }}
          </p>
          {% endif %}
        </div>

        {# Column 2: Products #}
        <div class="col-6 col-sm-3 col-lg-2">
          {{ page.footer_second }}
          {% if page.footer_second|render|striptags|trim is empty %}
          <h4 class="ob-footer__col-title">{{ zh ? '产品' : 'Products' }}</h4>
          <a href="{{ zh ? '/zh/taxonomy/term/331' : '/en/taxonomy/term/331' }}">{{ zh ? '直播编码与远程制作' : 'Live Encoding & Remote Production' }}</a>
          <a href="{{ zh ? '/zh/taxonomy/term/332' : '/en/taxonomy/term/332' }}">{{ zh ? '视音频处理' : 'Audio/Video Processing' }}</a>
          <a href="{{ zh ? '/zh/taxonomy/term/333' : '/en/taxonomy/term/333' }}">{{ zh ? '播出与存储' : 'Playout & Storage' }}</a>
