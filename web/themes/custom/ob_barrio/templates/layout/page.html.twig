{#
/**
 * @file
 * OB Barrio page template — corporate satellite/broadcast tech site.
 *
 * Regions:
 *   header, primary_menu, hero, hero_visual,
 *   highlighted, breadcrumb, sidebar_first, content, sidebar_second,
 *   features, solutions, services, partners,
 *   footer_first, footer_second, footer_third, footer_fourth, footer_bottom.
 */
#}
{% set sidebar_first_exists  = page.sidebar_first|render|striptags('<img><video><audio><drupal-render-placeholder>')|trim is not empty %}
{% set sidebar_second_exists = page.sidebar_second|render|striptags('<img><video><audio><drupal-render-placeholder>')|trim is not empty %}
{% set hero_visual_exists    = page.hero_visual|render|striptags('<img><video><audio><drupal-render-placeholder>')|trim is not empty %}
{% set zh = (current_langcode == 'zh-hans') %}

<div id="page-wrapper">
  <div id="page">

    <a href="#main-content" class="visually-hidden-focusable">{{ 'Skip to main content'|t }}</a>

    {# ── HEADER — sticky, 62 px ── #}
    <header id="site-header" class="ob-header sticky-top" role="banner">
      <div class="ob-header__topbar"></div>
      <div class="container">
        <div class="ob-header__inner">

          <div class="ob-header__brand">
            {{ page.header }}
          </div>

          <div class="ob-header__primary-region">
            {{ page.primary_menu }}
          </div>

          <button class="navbar-toggler d-lg-none ms-auto"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#ob-mobile-nav"
                  aria-controls="ob-mobile-nav"
                  aria-expanded="false"
                  aria-label="{{ 'Toggle navigation'|t }}">
            <span class="navbar-toggler-icon"></span>
          </button>

        </div>

        <div class="collapse d-lg-none" id="ob-mobile-nav">
          <div class="ob-mobile-menu">
            {{ page.primary_menu }}
          </div>
        </div>

      </div>
    </header>

    {# ── HERO — dark navy gradient, two-column layout ── #}
    {% if page.hero or hero_visual_exists %}
    <section class="ob-hero{% if not hero_visual_exists %} ob-hero--centered{% endif %}">
      <div class="ob-hero__stripe"></div>
      <div class="ob-hero__dots" aria-hidden="true"></div>
      <div class="ob-hero__glow ob-hero__glow--top" aria-hidden="true"></div>
      <div class="ob-hero__glow ob-hero__glow--bottom" aria-hidden="true"></div>
      <div class="container position-relative">
        <div class="ob-hero__layout">
          {% if page.hero %}
          <div class="ob-hero__text">
            {{ page.hero }}
          </div>
          {% endif %}
          {% if hero_visual_exists %}
          <div class="ob-hero__visual">
            {{ page.hero_visual }}
          </div>
          {% endif %}
        </div>
      </div>
    </section>
    {% endif %}

    {# ── HIGHLIGHTED / MESSAGES ── #}
    {% if page.highlighted %}
    <div class="highlighted">
      <aside class="container section clearfix" role="complementary">
        {{ page.highlighted }}
      </aside>
    </div>
    {% endif %}

    {# ── BREADCRUMB BAR — full-width background band ── #}
    {% if page.breadcrumb %}
    <div class="ob-breadcrumb-bar">
      <div class="container">
        <div class="ob-breadcrumb-region">
          {{ page.breadcrumb }}
        </div>
      </div>
    </div>
    {% endif %}

    {# ── MAIN CONTENT AREA ── #}
    <div id="main-wrapper" class="layout-main-wrapper clearfix">
      <div id="main" class="container">

        <a id="main-content" tabindex="-1"></a>

        <div class="row row-offcanvas row-offcanvas-left clearfix ob-page-layout align-items-start g-4">

          {% if sidebar_first_exists %}
          <aside class="col-12 col-lg-3 sidebar sidebar-first ob-sidebar" role="complementary">
            {{ page.sidebar_first }}
          </aside>
          {% endif %}

          <main
            class="col-12{% if sidebar_first_exists and sidebar_second_exists %} col-lg-6{% elseif sidebar_first_exists or sidebar_second_exists %} col-lg-9{% endif %} ob-content"
            id="content"
            role="main">
            <div class="ob-content-card">
              {{ page.content }}
            </div>
          </main>

          {% if sidebar_second_exists %}
          <aside class="col-12 col-lg-3 sidebar sidebar-second ob-sidebar" role="complementary">
            {{ page.sidebar_second }}
          </aside>
          {% endif %}

        </div>
      </div>
    </div>

    {# ── FEATURES / PRODUCTS ── light gray bg #}
    {% if page.features %}
    <section class="ob-features">
      <div class="container">
        <div class="ob-section-label">
          <span class="eyebrow">{{ 'Our Products'|t }}</span>
          <h2 class="ob-section-title">{{ 'Professional Broadcast &amp; Satellite Equipment'|t }}</h2>
          <p class="ob-section-sub">{{ 'End-to-end solutions for satellite communication, live production, and video networking.'|t }}</p>
        </div>
        <div class="ob-card-grid">
          {{ page.features }}
        </div>
      </div>
    </section>
    {% endif %}

    {# ── SOLUTIONS — industry verticals, white bg ── #}
    {% if page.solutions %}
    <section class="ob-solutions">
      <div class="container">
        <div class="ob-section-label ob-section-label--center">
          <span class="eyebrow">{{ 'Industry Solutions'|t }}</span>
          <h2 class="ob-section-title">{{ 'Built for Every Workflow'|t }}</h2>
          <p class="ob-section-sub">{{ 'From broadcast studios to remote field operations — we deliver purpose-built technology.'|t }}</p>
        </div>
        {{ page.solutions }}
      </div>
    </section>
    {% endif %}

    {# ── SERVICES — dark navy bg ── #}
    {% if page.services %}
    <section class="ob-services">
      <div class="container">
        <div class="ob-section-label ob-section-label--dark">
          <span class="eyebrow ob-eyebrow--light">{{ 'What We Offer'|t }}</span>
          <h2 class="ob-section-title ob-section-title--light">{{ 'Professional Services'|t }}</h2>
          <p class="ob-section-sub ob-section-sub--light">{{ 'Comprehensive support throughout your project lifecycle.'|t }}</p>
        </div>
        {{ page.services }}
      </div>
    </section>
    {% endif %}

    {# ── PARTNERS ── #}
    {% if page.partners %}
    <section class="ob-partners">
      <div class="container">
        {{ page.partners }}
      </div>
    </section>
    {% endif %}

    {# ── FOOTER ── #}
    <footer class="ob-footer" role="contentinfo">
      <div class="container">

        <div class="ob-footer__top row g-4">

          {# Column 1: Brand + description #}
          <div class="col-12 col-sm-6 col-lg-4 ob-footer__brand">
            {{ page.footer_first }}
            {# Fallback static content when region is empty #}
            {% if page.footer_first|render|striptags|trim is empty %}
            <div class="site-name">
              <a href="{{ zh ? '/zh' : '/en' }}">Oneband System</a>
            </div>
            <p class="ob-footer__desc">
              {{ zh
                ? '专注广播视频基础设施领域，为媒体机构提供专业系统集成与技术支持服务。'
                : 'Broadcast & video infrastructure specialists — system integration and technical services for media organisations.' }}
            </p>
            {% endif %}
          </div>

          {# Column 2: Products #}
          <div class="col-6 col-sm-3 col-lg-2">
            {{ page.footer_second }}
            {% if page.footer_second|render|striptags|trim is empty %}
            <h4 class="ob-footer__col-title">{{ zh ? '产品' : 'Products' }}</h4>
            <a href="{{ zh ? '/zh/taxonomy/term/331' : '/en/taxonomy/term/331' }}">{{ zh ? '直播编码与远程制作' : 'Live Encoding & Remote Production' }}</a>
            <a href="{{ zh ? '/zh/taxonomy/term/332' : '/en/taxonomy/term/332' }}">{{ zh ? '视音频处理' : 'Audio/Video Processing' }}</a>
            <a href="{{ zh ? '/zh/taxonomy/term/333' : '/en/taxonomy/term/333' }}">{{ zh ? '播出与存储' : 'Playout & Storage' }}</a>
            <a href="{{ zh ? '/zh/taxonomy/term/336' : '/en/taxonomy/term/336' }}">{{ zh ? '测试与监测' : 'Testing & Monitoring' }}</a>
            {% endif %}
          </div>

          {# Column 3: Solutions #}
          <div class="col-6 col-sm-3 col-lg-2">
            {{ page.footer_third }}
            {% if page.footer_third|render|striptags|trim is empty %}
            <h4 class="ob-footer__col-title">{{ zh ? '解决方案' : 'Solutions' }}</h4>
            <a href="{{ zh ? '/zh/taxonomy/term/340' : '/en/taxonomy/term/340' }}">{{ zh ? '传输与分发' : 'Transmission & Distribution' }}</a>
            <a href="{{ zh ? '/zh/taxonomy/term/337' : '/en/taxonomy/term/337' }}">{{ zh ? '数字前端系统集成' : 'Digital Front-end Integration' }}</a>
            <a href="{{ zh ? '/zh/taxonomy/term/339' : '/en/taxonomy/term/339' }}">{{ zh ? '演播室与总控' : 'Studio & Master Control' }}</a>
            <a href="{{ zh ? '/zh/taxonomy/term/338' : '/en/taxonomy/term/338' }}">{{ zh ? '直播与远程制作系统' : 'Live & Remote Production Systems' }}</a>
            {% endif %}
          </div>

          {# Column 4: Company links #}
          <div class="col-12 col-sm-6 col-lg-4 ob-footer__contact">
            {{ page.footer_fourth }}
            {% if page.footer_fourth|render|striptags|trim is empty %}
            <h4 class="ob-footer__col-title">{{ zh ? '公司' : 'Company' }}</h4>
            <a href="{{ zh ? '/zh/dashboard/category/service' : '/en/dashboard/category/service' }}">{{ zh ? '万博服务' : 'Services' }}</a>
            <a href="{{ zh ? '/zh/taxonomy/term/238' : '/en/taxonomy/term/238' }}">{{ zh ? '技术园地' : 'Tech Hub' }}</a>
            <a href="{{ zh ? '/zh/taxonomy/term/236' : '/en/taxonomy/term/236' }}">{{ zh ? '新闻中心' : 'Press Centre' }}</a>
            <a href="{{ zh ? '/zh/node/2' : '/en/node/2' }}">{{ zh ? '关于我们' : 'About Us' }}</a>
            {% endif %}
          </div>

        </div>{# /ob-footer__top #}

        <div class="ob-footer__bottom">
          {{ page.footer_bottom }}
          {% if page.footer_bottom|render|striptags|trim is empty %}
          <span>© {{ year }} {{ zh ? '万博视讯科技有限公司' : 'OB Barrio Technology Co., Ltd.' }}</span>
          <div class="ob-footer__legal">
            <a href="#">{{ zh ? '隐私政策' : 'Privacy Policy' }}</a>
            <a href="#">{{ zh ? '法律声明' : 'Legal Notice' }}</a>
          </div>
          {% endif %}
        </div>

      </div>
    </footer>

  </div>
</div>
