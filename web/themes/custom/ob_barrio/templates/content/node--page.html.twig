{#
/**
 * @file
 * OB Barrio — Basic Page node template (full page & teaser).
 *
 * Styled for GitBook / Linear / Stripe Docs aesthetic via docs-ui.css.
 *
 * Variables:
 *   node, label, url, content, page (bool), display_submitted,
 *   author_name, author_picture, author_attributes, date, metadata,
 *   title_prefix, title_suffix, title_attributes, attributes,
 *   content_attributes, view_mode.
 */
#}
{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky()   ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
    'ob-node-page',
  ]
%}
<article{{ attributes.addClass(classes) }}>

  {{ title_prefix }}

  {# ── Full-page view: doc header (tags + actions) + H1 + meta ── #}
  {% if page %}

    {# ── Doc header: taxonomy tags left, action buttons right ── #}
    <div class="ob-doc-header">
      <div class="ob-tags">
        {# Brand tag — field_brand (entity reference) #}
        {% if content.field_brand is defined and content.field_brand|render|striptags|trim is not empty %}
          <span class="ob-tag ob-tag--brand">{{ content.field_brand }}</span>
        {% endif %}
        {# Category / doc type tags — field_tags or field_category #}
        {% if content.field_tags is defined and content.field_tags|render|striptags|trim is not empty %}
          {% for item in content.field_tags['#items'] %}
            <span class="ob-tag ob-tag--category">{{ item.entity.label }}</span>
          {% endfor %}
        {% endif %}
        {% if content.field_category is defined and content.field_category|render|striptags|trim is not empty %}
          {% for item in content.field_category['#items'] %}
            <span class="ob-tag ob-tag--category">{{ item.entity.label }}</span>
          {% endfor %}
        {% endif %}
      </div>

      {# Action buttons — edit, share, print #}
      <div class="ob-doc-actions" aria-label="{{ 'Document actions'|t }}">
        {% if node.access('update') %}
        <a href="{{ url }}/edit" class="ob-action-btn" title="{{ 'Edit'|t }}" aria-label="{{ 'Edit'|t }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </a>
        {% endif %}
        <button class="ob-action-btn ob-share-btn" title="{{ 'Share'|t }}" aria-label="{{ 'Share'|t }}" onclick="navigator.share ? navigator.share({title: document.title, url: location.href}) : navigator.clipboard.writeText(location.href)" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
          </svg>
        </button>
        <button class="ob-action-btn ob-print-btn" title="{{ 'Print / Download'|t }}" aria-label="{{ 'Print'|t }}" onclick="window.print()" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 6 2 18 2 18 9"/>
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
          </svg>
        </button>
      </div>
    </div>

    <h1{{ title_attributes.addClass('ob-node-title') }}>{{ label }}</h1>

  {# ── Teaser / search result: linked H2 ── #}
  {% else %}
    <h2{{ title_attributes.addClass('ob-node-teaser-title') }}>
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h2>
  {% endif %}

  {{ title_suffix }}

  {# ── Meta row: author · 更新于 date · reading time ── #}
  {% if display_submitted %}
  <div class="ob-node-meta">

    {% if author_picture %}
    <div class="ob-node-meta__avatar">
      {{ author_picture }}
    </div>
    {% endif %}

    <div class="ob-node-meta__info">
      <span class="ob-node-meta__sep" aria-hidden="true">{{ '更新于'|t }}</span>
      <time class="ob-node-meta__date">{{ date }}</time>
      <span class="ob-node-meta__sep" aria-hidden="true">·</span>
      <span{{ author_attributes }} class="ob-node-meta__author">
        {{- '作者'|t }} {{ author_name -}}
      </span>
      {{ metadata }}
      {# Reading time populated by ob_barrio.js behavior #}
      <span class="ob-reading-time" aria-label="{{ 'Reading time'|t }}"></span>
    </div>

  </div>
  {% endif %}

  {# ── Body / fields ── #}
  <div{{ content_attributes.addClass('node__content', 'ob-node-content') }}>
    {{ content }}
  </div>

</article>
