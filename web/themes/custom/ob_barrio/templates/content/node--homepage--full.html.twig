{#
/**
 * @file
 * OB Barrio — Homepage node template (full view mode only).
 *
 * Renders the site front page from the active `homepage` node's
 * field_home_* fields (hero, product cards, service steps, partner
 * brands, CTA banner). Sections that remain hardcoded (stats, section
 * aria-labels, latest-articles header) are wrapped in `|t` for bilingual
 * support — see /admin/config/regional/translate for the English
 * translations these need.
 *
 * Only the homepage content itself is output here — no title, no
 * submitted/meta info, no node default wrapper — since this replaces the
 * old page--front.html.twig wholesale (header/footer live in page.html.twig).
 *
 * Variables:
 *   node, content
 *   current_langcode, latest_articles — set by
 *     ob_barrio_preprocess_node__homepage()
 *   directory — theme path, for placeholder SVGs.
 */
#}
{% set zh = (current_langcode == 'zh-hans') %}

{# ════════════════════════════════════════
   SECTION 1 — HERO BANNER
   ════════════════════════════════════════ #}
<section class="ob-front-hero" aria-label="{{ 'Hero'|t }}">
  <div class="ob-front-hero__bg-dots" aria-hidden="true"></div>
  <div class="ob-front-hero__glow" aria-hidden="true"></div>

  <div class="container">
    <div class="ob-front-hero__inner">

      {# Pill tag row — field_home_hero_pills (multi-value).
         Collected into a plain array first: Twig disallows `loop.last`
         inside a `for ... if`-filtered loop. #}
      {% set pill_items = [] %}
      {% for key, pill in content.field_home_hero_pills %}
        {% if key|first != '#' %}
          {% set pill_items = pill_items|merge([pill]) %}
        {% endif %}
      {% endfor %}
      <div class="ob-front-hero__pills">
        {% for pill in pill_items %}
          <span class="ob-front-pill ob-front-pill--brand">{{ pill }}</span>
          {% if not loop.last %}<span class="ob-front-pill ob-front-pill--sep" aria-hidden="true">·</span>{% endif %}
        {% endfor %}
      </div>

      {# Main headline — field_home_hero_title (formatted, hero_title format) #}
      <h1 class="ob-front-hero__title">
        {{ content.field_home_hero_title.0 }}
      </h1>

      {# Sub-headline — field_home_hero_subtitle #}
      <p class="ob-front-hero__sub">
        {{ content.field_home_hero_subtitle.0 }}
      </p>

      {# CTA Buttons — field_home_hero_btn1 / btn2 #}
      <div class="ob-front-hero__btns">
        {% set hero_btn1 = node.field_home_hero_btn1.0 %}
        {% if hero_btn1 %}
        <a href="{{ hero_btn1.getUrl().toString() }}" class="ob-front-btn ob-front-btn--primary">
          {{ hero_btn1.title }}
        </a>
        {% endif %}
        {% set hero_btn2 = node.field_home_hero_btn2.0 %}
        {% if hero_btn2 %}
        <a href="{{ hero_btn2.getUrl().toString() }}" class="ob-front-btn ob-front-btn--outline">
          {{ hero_btn2.title }}
        </a>
        {% endif %}
      </div>

      {# Stats row — hardcoded #}
      <div class="ob-front-hero__stats">
        <div class="ob-front-stat">
          <span class="ob-front-stat__num">20+</span>
          <span class="ob-front-stat__label">{{ '年行业经验'|t }}</span>
        </div>
        <span class="ob-front-stat__divider" aria-hidden="true"></span>
        <div class="ob-front-stat">
          <span class="ob-front-stat__num">500+</span>
          <span class="ob-front-stat__label">{{ '客户部署案例'|t }}</span>
        </div>
        <span class="ob-front-stat__divider" aria-hidden="true"></span>
        <div class="ob-front-stat">
          <span class="ob-front-stat__num">24/7</span>
          <span class="ob-front-stat__label">{{ '技术支持保障'|t }}</span>
        </div>
      </div>

    </div>
  </div>
</section>

{# ════════════════════════════════════════
   SECTION 2 — CORE PRODUCTS
   ════════════════════════════════════════ #}
<section class="ob-front-products" aria-label="{{ '核心产品'|t }}">
  <div class="container">

    <div class="ob-front-section-head ob-front-section-head--split">
      <div class="ob-front-section-head__left">
        <span class="ob-eyebrow">{{ '核心产品'|t }}</span>
        <h2 class="ob-front-section-title">
          {{ '专业视音频处理'|t }}
        </h2>
      </div>
      <div class="ob-front-section-head__right">
        <p class="ob-front-section-desc">
          {{ '直播与远程制作、视音频处理、播出与存储、传输与分发、演播室集成。'|t }}
        </p>
      </div>
    </div>

    {# field_home_product_cards — looped to avoid the field wrapper div,
       which would break the CSS grid's direct-child layout. #}
    <div class="ob-front-product-grid">
      {% for key, card in content.field_home_product_cards if key|first != '#' %}
        {{ card }}
      {% endfor %}
    </div>{# /ob-front-product-grid #}
  </div>
</section>

{# ════════════════════════════════════════
   SECTION 3 — SERVICE CAPABILITIES
   ════════════════════════════════════════ #}
<section class="ob-front-services" aria-label="{{ '服务能力'|t({}, {'context': 'aria label'}) }}">
  <div class="container">

    <div class="ob-front-section-head">
      <span class="ob-eyebrow ob-eyebrow--light">{{ content.field_home_services_eyebrow.0 }}</span>
      <h2 class="ob-front-section-title ob-front-section-title--light">
        {{ content.field_home_services_title.0 }}
      </h2>
    </div>

    {# field_home_service_steps — looped to avoid the field wrapper div,
       same pattern as field_home_product_cards above. #}
    <div class="ob-front-services-grid">
      {% for key, step in content.field_home_service_steps if key|first != '#' %}
        {{ step }}
      {% endfor %}
    </div>

  </div>
</section>

{# ════════════════════════════════════════
   SECTION 4 — PARTNER BRANDS
   ════════════════════════════════════════ #}
<section class="ob-front-brands" aria-label="{{ '合作品牌'|t }}">
  <div class="container">

    <div class="ob-front-section-head ob-front-section-head--center">
      <span class="ob-eyebrow">{{ content.field_home_brands_eyebrow.0 }}</span>
      <h2 class="ob-front-section-title">
        {{ content.field_home_brands_title.0 }}
      </h2>
    </div>

    {# field_home_brand_items — looped to avoid the field wrapper div. #}
    <div class="ob-front-brands-grid">
      {% for key, brand in content.field_home_brand_items if key|first != '#' %}
        {{ brand }}
      {% endfor %}
    </div>

  </div>
</section>

{# ════════════════════════════════════════
   SECTION 5 — LATEST ARTICLES (header hardcoded, list dynamic)
   ════════════════════════════════════════ #}
{% if latest_articles is not empty %}
<section class="ob-front-articles" aria-label="{{ '最新文章'|t }}">
  <div class="container">

    <div class="ob-front-section-head ob-front-section-head--split">
      <div class="ob-front-section-head__left">
        <h2 class="ob-front-section-title">
          {{ '最新文章'|t }}
        </h2>
      </div>
      <div class="ob-front-section-head__right">
        <a href="{{ zh ? '/zh/dashboard/category/article' : '/en/dashboard/category/article' }}"
           class="ob-front-articles__more">
          {{ '查看全部文章 →'|t }}
        </a>
      </div>
    </div>

    <div class="ob-front-articles-grid">
      {% for article in latest_articles %}
      <article class="ob-article-card">
        {% if article.image_url %}
        <a href="{{ article.url }}" class="ob-article-card__img-wrap" tabindex="-1" aria-hidden="true">
          <img src="{{ article.image_url }}" alt="{{ article.title }}" class="ob-article-card__img" loading="lazy">
        </a>
        {% else %}
        {% set placeholders = ['placeholder-satellite.svg', 'placeholder-rack.svg', 'placeholder-network.svg'] %}
        <a href="{{ article.url }}" class="ob-article-card__img-wrap ob-article-card__img-wrap--placeholder" tabindex="-1" aria-hidden="true">
          <img class="ob-article-card__img-placeholder"
               src="/{{ directory }}/images/index/{{ placeholders[loop.index0 % 3] }}"
               alt="" aria-hidden="true" loading="lazy">
        </a>
        {% endif %}

        <div class="ob-article-card__body">
          <div class="ob-article-card__meta">
            {% if article.brand %}
            <span class="ob-article-card__brand">{{ article.brand }}</span>
            <span class="ob-article-card__sep" aria-hidden="true">·</span>
            {% endif %}
            <time class="ob-article-card__date" datetime="{{ article.date }}">{{ article.date }}</time>
          </div>

          <h3 class="ob-article-card__title">
            <a href="{{ article.url }}">{{ article.title }}</a>
          </h3>

          {% if article.summary %}
          <p class="ob-article-card__summary">{{ article.summary }}</p>
          {% endif %}

          <a href="{{ article.url }}" class="ob-article-card__read-more">
            {{ '阅读全文'|t }} →
          </a>
        </div>
      </article>
      {% endfor %}
    </div>

  </div>
</section>
{% endif %}

{# ════════════════════════════════════════
   SECTION 6 — CTA BANNER
   ════════════════════════════════════════ #}
<section class="ob-front-cta" aria-label="{{ '联系我们'|t }}">
  <div class="container">
    <div class="ob-front-cta__inner">

      <h2 class="ob-front-cta__title">
        {{ content.field_home_cta_title.0 }}
      </h2>
      <p class="ob-front-cta__desc">
        {{ content.field_home_cta_subtitle.0 }}
      </p>

      <div class="ob-front-cta__btns">
        {% set cta_btn1 = node.field_home_cta_btn1.0 %}
        {% if cta_btn1 %}
        <a href="{{ cta_btn1.getUrl().toString() }}" class="ob-front-btn ob-front-btn--white-outline">
          {{ cta_btn1.title }}
        </a>
        {% endif %}
        {% set cta_btn2 = node.field_home_cta_btn2.0 %}
        {% if cta_btn2 %}
        <a href="{{ cta_btn2.getUrl().toString() }}" class="ob-front-btn ob-front-btn--white-solid">
          {{ cta_btn2.title }}
        </a>
        {% endif %}
      </div>

    </div>
  </div>
</section>
