{#
/**
 * @file
 * OB Barrio — Article node template (full page & teaser).
 *
 * Extra variables from ob_barrio_preprocess_node():
 *   - formatted_date: '2025年4月1日'
 *   - read_more_url:  canonical URL string
 *   - prev_node / next_node: NodeInterface|null (same brand, adjacent by created time)
 *   - current_langcode: 'zh-hans' | 'en'
 *   - doc_rev: 'DOC-REV 2026.04 · CN'
 */
#}
{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky()   ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
    'ob-node-article',
  ]
%}
<article{{ attributes.addClass(classes) }}>

  {{ title_prefix }}

  {# ── Full-page view ── #}
  {% if page %}

    <div class="ob-doc-header">
      {# Tags: read directly from node to avoid Drupal field label wrappers #}
      <div class="ob-tags">
        {% if not node.field_article_brand.isEmpty %}
          <span class="ob-tag ob-tag--brand">{{ node.field_article_brand.entity.label|upper }}</span>
        {% endif %}
        {% if not node.field_tags.isEmpty %}
          {% for item in node.field_tags %}
            <span class="ob-tag ob-tag--category">{{ item.entity.label }}</span>
          {% endfor %}
        {% endif %}
      </div>

      <div class="ob-doc-actions" aria-label="{{ 'Document actions'|t }}">
        {% if node_can_edit %}
        <a href="{{ url }}/edit" class="ob-action-btn" title="{{ 'Edit'|t }}" aria-label="{{ 'Edit'|t }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </a>
        {% endif %}
        <button class="ob-action-btn ob-share-btn" title="{{ 'Share'|t }}" aria-label="{{ 'Share'|t }}" onclick="navigator.share ? navigator.share({title: document.title, url: location.href}) : navigator.clipboard.writeText(location.href)" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
          </svg>
        </button>
        <button class="ob-action-btn ob-print-btn" title="{{ 'Print / Download'|t }}" aria-label="{{ 'Print'|t }}" onclick="window.print()" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 6 2 18 2 18 9"/>
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
          </svg>
        </button>
      </div>
    </div>

    {# Title is rendered by the page title block — do NOT repeat it here #}

  {# ── Teaser: linked H2 ── #}
  {% else %}
    <h2{{ title_attributes.addClass('ob-node-teaser-title') }}>
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h2>
  {% endif %}

  {{ title_suffix }}

  {% if display_submitted %}
  <div class="ob-node-meta">
    {% if author_picture %}
    <div class="ob-node-meta__avatar">{{ author_picture }}</div>
    {% endif %}
    <div class="ob-node-meta__info">
      <span class="ob-node-meta__sep" aria-hidden="true">{{ '更新于'|t }}</span>
      <time class="ob-node-meta__date">{{ date }}</time>
      <span class="ob-node-meta__sep" aria-hidden="true">·</span>
      <span{{ author_attributes }} class="ob-node-meta__author">{{ '作者'|t }} {{ author_name }}</span>
      {{ metadata }}
      <span class="ob-reading-time" aria-label="{{ 'Reading time'|t }}"></span>
    </div>
  </div>
  {% endif %}

  <div{{ content_attributes.addClass('node__content', 'ob-node-content') }}>
    {# Exclude brand/tags — already shown in the header bar above #}
    {{ content|without('field_article_brand', 'field_tags') }}
  </div>

  {# ── Prev / Next navigation (full page only) ── #}
  {% if page and (prev_node or next_node) %}
  <div class="article-nav" role="navigation" aria-label="{{ 'Article navigation'|t }}">

    <div class="article-nav__prev">
      {% if prev_node %}
        <a href="{{ path('entity.node.canonical', {'node': prev_node.id()}) }}"
           class="article-nav__btn"
           title="{{ prev_node.label }}">
          {% if current_langcode == 'zh-hans' %}← 上一篇{% else %}← Previous{% endif %}
          <span class="article-nav__title">{{ prev_node.label }}</span>
        </a>
      {% else %}
        <span class="article-nav__btn article-nav__btn--disabled" aria-hidden="true">
          {% if current_langcode == 'zh-hans' %}← 上一篇{% else %}← Previous{% endif %}
        </span>
      {% endif %}
    </div>

    <div class="article-nav__next">
      {% if next_node %}
        <a href="{{ path('entity.node.canonical', {'node': next_node.id()}) }}"
           class="article-nav__btn article-nav__btn--right"
           title="{{ next_node.label }}">
          <span class="article-nav__title">{{ next_node.label }}</span>
          {% if current_langcode == 'zh-hans' %}下一篇 →{% else %}Next →{% endif %}
        </a>
      {% else %}
        <span class="article-nav__btn article-nav__btn--right article-nav__btn--disabled" aria-hidden="true">
          {% if current_langcode == 'zh-hans' %}下一篇 →{% else %}Next →{% endif %}
        </span>
      {% endif %}
    </div>

  </div>

  {% if doc_rev %}
  <div class="article-nav__docrev">{{ doc_rev }}</div>
  {% endif %}

  {% endif %}

</article>
