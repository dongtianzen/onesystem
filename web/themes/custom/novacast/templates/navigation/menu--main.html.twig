{#
/**
 * @file
 * NovaCast: Primary navigation menu.
 *
 * Variables:
 * - items: Nested list of menu items.
 *   Each item has:
 *   - title, url, in_active_trail, is_expanded, below (children)
 */
#}
{% import _self as menus %}

{#
  Recursive macro: renders one level of menu items.
  @param items     — array of menu item objects
  @param depth     — nesting depth (0 = top level)
#}
{% macro menu_links(items, depth) %}
  {% import _self as menus %}
  {% if items %}
    <ul class="{% if depth == 0 %}primary-nav{% else %}primary-nav__dropdown{% endif %}"
        {% if depth > 0 %}role="menu"{% endif %}>
      {% for item in items %}
        {% set has_children = item.below is not empty %}
        {% set is_active = item.in_active_trail %}
        <li class="primary-nav__item{% if is_active %} is-active{% endif %}{% if has_children %} has-children{% endif %}"
            {% if depth > 0 %}role="none"{% endif %}>
          <a href="{{ item.url }}"
             class="primary-nav__link"
             {% if is_active %}aria-current="page"{% endif %}
             {% if has_children %}
               aria-haspopup="true"
               aria-expanded="false"
             {% endif %}
             {% if depth > 0 %}role="menuitem"{% endif %}>
            {{ item.title }}
          </a>
          {% if has_children %}
            {{ menus.menu_links(item.below, depth + 1) }}
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}

{{ menus.menu_links(items, 0) }}
