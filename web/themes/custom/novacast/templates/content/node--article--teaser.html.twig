{#
/**
 * @file
 * NovaCast: Article node teaser — used in listing / views pages.
 */
#}
<article{{ attributes.addClass('node', 'node--type-article', 'node--teaser') }}>

  {{ title_prefix }}
  <h3{{ title_attributes.addClass('node__title') }}>
    <a href="{{ url }}" rel="bookmark">{{ label }}</a>
  </h3>
  {{ title_suffix }}

  {# Date + badge row #}
  <div class="node__meta">
    <time class="node__date" datetime="{{ node.getCreatedTime()|date('c') }}">
      {% if date_cn %}{{ date_cn }}{% else %}{{ date }}{% endif %}
    </time>
    <span class="badge badge-tag">{{ 'Article'|t }}</span>
  </div>

  {# Summary / body excerpt #}
  {% if content.body %}
    <div class="node__summary">
      {{ content.body }}
    </div>
  {% endif %}

  {# Read more link #}
  <div class="node__read-more">
    <a href="{{ url }}" class="card__link" aria-label="{{ 'Read more about @title'|t({'@title': label}) }}">
      {{ 'Read more'|t }}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>

</article>
