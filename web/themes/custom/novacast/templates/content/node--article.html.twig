{#
/**
 * @file
 * NovaCast: Article node — full page view.
 *
 * Additional variables vs generic node.html.twig:
 * - date_cn: Chinese date string (Y年n月j日).
 * - read_more: Canonical node URL.
 */
#}
<article{{ attributes.addClass('node', 'node--type-article', 'node--full') }}>

  {{ title_prefix }}
  {% if not page %}
    <h1{{ title_attributes.addClass('node__title') }}>
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h1>
  {% else %}
    <h1{{ title_attributes.addClass('node__title') }}>{{ label }}</h1>
  {% endif %}
  {{ title_suffix }}

  {# Meta row: author + date #}
  <div class="node__meta">
    {% if display_submitted %}
      <span class="node__author">
        {{ 'By'|t }} {{ author_name }}
      </span>
      <time class="node__date" datetime="{{ node.getCreatedTime()|date('c') }}">
        {% if date_cn %}{{ date_cn }}{% else %}{{ date }}{% endif %}
      </time>
    {% endif %}

    {# Content-type badge #}
    <span class="badge badge-tag">{{ node.bundle|capitalize }}</span>
  </div>

  {# Main content #}
  <div{{ content_attributes.addClass('node__body') }}>
    {{ content|without('field_tags', 'links') }}
  </div>

  {# Tags #}
  {% if content.field_tags %}
    <div class="node__tags">
      {{ content.field_tags }}
    </div>
  {% endif %}

  {# Node links (comment link, etc.) #}
  {% if content.links %}
    <div class="node__links">
      {{ content.links }}
    </div>
  {% endif %}

</article>
