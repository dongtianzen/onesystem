{#
/**
 * @file
 * NovaCast: Generic node template (all types, all view modes).
 *
 * Variables:
 * - node: The node entity.
 * - view_mode: Current view mode (full, teaser, etc.).
 * - label: Node title.
 * - content: Rendered fields.
 * - url: Node URL.
 * - page: TRUE if displayed as a full page (not teaser).
 * - logged_in: TRUE if user is logged in.
 * - attributes: HTML attributes for wrapper.
 * - title_attributes: Attributes for the title element.
 * - content_attributes: Attributes for the content wrapper.
 * - author_name: Display name of node author.
 * - date: Formatted creation date (from Drupal default).
 * - date_cn: Chinese-formatted date (from novacast_preprocess_node).
 * - read_more: Node URL string (from novacast_preprocess_node).
 */
#}
<article{{ attributes.addClass('node', 'node--type-' ~ node.bundle, 'node--view-mode-' ~ view_mode|clean_class) }}>

  {{ title_prefix }}
  {% if not page %}
    <h2{{ title_attributes.addClass('node__title') }}>
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h2>
  {% endif %}
  {{ title_suffix }}

  {% if display_submitted %}
    <div class="node__meta">
      <span class="node__author">{{ author_name }}</span>
      {% if date_cn %}
        <time class="node__date" datetime="{{ node.getCreatedTime()|date('c') }}">
          {{ date_cn }}
        </time>
      {% else %}
        <time class="node__date" datetime="{{ node.getCreatedTime()|date('c') }}">
          {{ date }}
        </time>
      {% endif %}
    </div>
  {% endif %}

  <div{{ content_attributes.addClass('node__body') }}>
    {{ content }}
  </div>

</article>
