{#
/**
 * @file
 * NovaCast: Breadcrumb trail.
 *
 * Variables:
 * - breadcrumb: Array of breadcrumb items (text + url).
 */
#}
{% if breadcrumb %}
  <nav class="breadcrumb" aria-label="{{ 'Breadcrumb'|t }}">
    <ol class="breadcrumb__list">
      {% for item in breadcrumb %}
        <li class="breadcrumb__item">
          {% if not loop.last %}
            <a class="breadcrumb__link" href="{{ item.url }}">{{ item.text }}</a>
            <span class="breadcrumb__separator" aria-hidden="true">/</span>
          {% else %}
            <span class="breadcrumb__current" aria-current="page">{{ item.text }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
{% endif %}
