{#
/**
 * @file
 * NovaCast: Pager template.
 *
 * Variables:
 * - heading_id: Accessible label ID for the pager.
 * - items: Pager item objects (first, previous, pages, next, last).
 * - current: Current page number.
 * - ellipses: Flags for leading/trailing ellipses.
 */
#}
{% if items %}
  <nav class="pager" role="navigation" aria-labelledby="{{ heading_id }}">
    <h4 id="{{ heading_id }}" class="visually-hidden">{{ 'Pagination'|t }}</h4>

    <ul class="pager__list">

      {# First page #}
      {% if items.first %}
        <li class="pager__item pager__item--first">
          <a href="{{ items.first.href }}"
             title="{{ 'Go to first page'|t }}"
             {{ items.first.attributes|without('href', 'title') }}
             aria-label="{{ 'First page'|t }}">
            &laquo;
          </a>
        </li>
      {% endif %}

      {# Previous page #}
      {% if items.previous %}
        <li class="pager__item pager__item--previous">
          <a href="{{ items.previous.href }}"
             title="{{ 'Go to previous page'|t }}"
             {{ items.previous.attributes|without('href', 'title') }}
             rel="prev"
             aria-label="{{ 'Previous page'|t }}">
            &lsaquo;
          </a>
        </li>
      {% endif %}

      {# Leading ellipsis #}
      {% if ellipses.previous %}
        <li class="pager__item pager__item--ellipsis" role="presentation">
          <span>&hellip;</span>
        </li>
      {% endif %}

      {# Numbered pages #}
      {% for key, item in items.pages %}
        <li class="pager__item{% if current == key %} pager__item--current{% endif %}">
          {% if current == key %}
            <span aria-current="page"
                  aria-label="{{ 'Page @num, current page'|t({'@num': key}) }}">
              {{- key -}}
            </span>
          {% else %}
            <a href="{{ item.href }}"
               title="{{ 'Go to page @num'|t({'@num': key}) }}"
               {{ item.attributes|without('href', 'title') }}
               aria-label="{{ 'Page @num'|t({'@num': key}) }}">
              {{- key -}}
            </a>
          {% endif %}
        </li>
      {% endfor %}

      {# Trailing ellipsis #}
      {% if ellipses.next %}
        <li class="pager__item pager__item--ellipsis" role="presentation">
          <span>&hellip;</span>
        </li>
      {% endif %}

      {# Next page #}
      {% if items.next %}
        <li class="pager__item pager__item--next">
          <a href="{{ items.next.href }}"
             title="{{ 'Go to next page'|t }}"
             {{ items.next.attributes|without('href', 'title') }}
             rel="next"
             aria-label="{{ 'Next page'|t }}">
            &rsaquo;
          </a>
        </li>
      {% endif %}

      {# Last page #}
      {% if items.last %}
        <li class="pager__item pager__item--last">
          <a href="{{ items.last.href }}"
             title="{{ 'Go to last page'|t }}"
             {{ items.last.attributes|without('href', 'title') }}
             aria-label="{{ 'Last page'|t }}">
            &raquo;
          </a>
        </li>
      {% endif %}

    </ul>
  </nav>
{% endif %}
